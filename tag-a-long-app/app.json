{
  "expo": {
    "name": "Tag-A-Long",
    "slug": "tag-a-long-app",
    "scheme": "tagalong",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tagalong.app",
      "buildNumber": "1",
      "entitlements": {
        "aps-environment": "production"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Tag-A-Long uses your location to show you activities happening nearby.",
        "NSCameraUsageDescription": "Tag-A-Long uses your camera to take a photo for your activity or profile.",
        "NSPhotoLibraryUsageDescription": "Tag-A-Long accesses your photo library to let you choose a profile or activity photo.",
        "NSPhotoLibraryAddUsageDescription": "Tag-A-Long saves photos to your library.",
        "NSUserNotificationsUsageDescription": "Tag-A-Long sends you notifications when someone requests to join your activity or your request is accepted."
      }
    },
    "android": {
      "package": "com.tagalong.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.INTERNET",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications"
    ]
  }
}
